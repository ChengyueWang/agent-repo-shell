{
  "name": "agent-repo-shell",
  "displayName": "Agent Repo Shell",
  "description": "Bootstrap your agentic multi-repos project. Minimum distractions to iterate on specs. A VSCode panel to code like taking notes.",
  "version": "0.0.4",
  "publisher": "ChengyueWang",
  "license": "MIT",
  "preview": true,
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "AI",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "agent",
    "agentic",
    "claude",
    "claude-code",
    "anthropic",
    "repo browser",
    "sidebar",
    "markdown",
    "webview",
    "file overview",
    "lsp",
    "viewer",
    "navigation"
  ],
  "main": "./extension.js",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#FBF8F2",
    "theme": "light"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ChengyueWang/agent-repo-shell.git"
  },
  "bugs": {
    "url": "https://github.com/ChengyueWang/agent-repo-shell/issues"
  },
  "homepage": "https://github.com/ChengyueWang/agent-repo-shell#readme",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "agentRepoShell.openView",
        "title": "Agent Repo Shell: Open View",
        "icon": "icon.png"
      },
      {
        "command": "agentRepoShell.previewOverview",
        "title": "Agent Repo Shell: Preview File Overview"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "agentRepoShell.openView",
          "group": "navigation",
          "when": "config.agentRepoShell.showEditorTitleIcon"
        }
      ]
    },
    "configuration": {
      "title": "Agent Repo Shell",
      "properties": {
        "agentRepoShell.showEditorTitleIcon": {
          "type": "boolean",
          "default": true,
          "description": "Show a one-click 'Open View' icon in the editor title bar (top-right of each editor tab)."
        }
      }
    }
  },
  "dependencies": {
    "@recogito/text-annotator": "^4.1.0",
    "highlight.js": "^11.9.0",
    "html2canvas": "^1.4.1",
    "markdown-it": "^14.2.0",
    "marked": "^12.0.0",
    "marked-highlight": "^2.2.4",
    "mermaid": "^10.9.1",
    "turndown": "^7.2.4"
  }
}
